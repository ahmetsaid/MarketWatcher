{
  "name": "market-tracker",
  "version": "1.1.1",
  "description": "Desktop portfolio tracker widget",
  "main": "main.js",
  "author": "MarketTracker",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac"
  },
  "build": {
    "appId": "com.markettracker.app",
    "productName": "Market Tracker",
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.finance",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "roll-calculator.html",
      "roll-calculator.js",
      "portfolio.json",
      "settings.json"
    ],
    "extraResources": []
  },
  "dependencies": {
    "yahoo-finance2": "^2.14.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
